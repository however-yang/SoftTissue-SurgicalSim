// XPBDSolver.compute — NeoHookean 弹性 + Graph Coloring GS
// 参考: FantasyVR/neohookean_XPBD (Taichi 实现)
// 论文: Peng Yu et al., "Parallel Constraint Graph Partitioning
//       and Coloring for Realtime Soft-Body Cutting", EG 2025

#pragma kernel CSIntegrate
#pragma kernel CSSolveEdges
#pragma kernel CSSolveNeoHookeanDev
#pragma kernel CSSolveNeoHookeanHyd
#pragma kernel CSSolveNeoHookeanDevHyd
#pragma kernel CSPostSolve
#pragma kernel CSGroundCollision
#pragma kernel CSToolCollision
#pragma kernel CSSolveSurfaceToolContacts

// ═══════════════════════════════════════════════════════
// Uniforms
// ═══════════════════════════════════════════════════════
float  _Dt;
float  _GravityX, _GravityY, _GravityZ;
float  _EdgeAlpha;       // edgeCompliance / (dt*dt)
float  _GroundY;
float  _ToolContactDistance;
float  _ToolContactAlpha;

// Tool collision (Multi-Capsule SDF)
float4 _Capsule0A;        // xyz=端点A, w=半径
float4 _Capsule0B;        // xyz=端点B, w=unused
float4 _Capsule1A;        // xyz=端点A, w=半径
float4 _Capsule1B;        // xyz=端点B, w=unused
float4 _Capsule2A;        // xyz=端点A (shaft), w=半径
float4 _Capsule2B;        // xyz=端点B (shaft), w=unused
float4 _PrevCapsule0A;    // xyz=上一帧端点A, w=半径
float4 _PrevCapsule0B;    // xyz=上一帧端点B, w=unused
float4 _PrevCapsule1A;
float4 _PrevCapsule1B;
float4 _PrevCapsule2A;
float4 _PrevCapsule2B;
float4 _ToolBBoxMin;      // xyz=AABB min
float4 _ToolBBoxMax;      // xyz=AABB max, w=胶囊体数量 (0=off)
float  _Damping;         // 速度阻尼 (0~1)
float  _Omega;           // SOR 松弛因子 (0~1), 模拟 Jacobi 平均化效果
uint   _NumParticles;
uint   _NumTets;
uint   _NumEdges;
uint   _NumSurfaceTris;
uint   _GroupOffset;      // Graph Coloring: 当前颜色组的起始偏移
uint   _GroupCount;       // Graph Coloring: 当前颜色组的大小

// ═══════════════════════════════════════════════════════
// Buffers
// ═══════════════════════════════════════════════════════
uint   _SurfaceGroupOffset;
uint   _SurfaceGroupCount;

RWStructuredBuffer<float4> _Positions;
RWStructuredBuffer<float4> _PrevPositions;
RWStructuredBuffer<float4> _Velocities;
RWStructuredBuffer<float>  _InvMasses;

StructuredBuffer<uint4>    _TetIds;
StructuredBuffer<float>    _RestVolumes;
StructuredBuffer<int>      _TetActive;

// NeoHookean: B^{-1} 矩阵 (每个 tet 一个 3x3，存储为 3 个 float4 = 9 floats)
// 布局: _InvRestMatrix[t*3+0] = row0, _InvRestMatrix[t*3+1] = row1, _InvRestMatrix[t*3+2] = row2
StructuredBuffer<float4>   _InvRestMatrix;

// NeoHookean: alpha 参数 (per-tet)
StructuredBuffer<float>    _AlphaDeviatoric;  // 1/(h^2 * mu * V)
StructuredBuffer<float>    _AlphaHydrostatic; // 1/(h^2 * lambda * V)

StructuredBuffer<uint2>    _EdgeIds;
StructuredBuffer<float>    _RestLengths;
StructuredBuffer<int>      _EdgeActive;
StructuredBuffer<int>      _ColorGroupFlat;      // tet 颜色组
StructuredBuffer<int>      _EdgeColorGroupFlat;   // edge 颜色组
StructuredBuffer<uint3>    _SurfaceTriIds;
StructuredBuffer<int>      _SurfaceTriColorGroupFlat;

// ═══════════════════════════════════════════════════════
// Helper functions
// ═══════════════════════════════════════════════════════

float det3x3(float3x3 M)
{
    return M[0][0] * (M[1][1]*M[2][2] - M[1][2]*M[2][1])
         - M[0][1] * (M[1][0]*M[2][2] - M[1][2]*M[2][0])
         + M[0][2] * (M[1][0]*M[2][1] - M[1][1]*M[2][0]);
}

float3x3 LoadInvRestMatrix(uint tetIdx)
{
    float4 r0 = _InvRestMatrix[tetIdx * 3 + 0];
    float4 r1 = _InvRestMatrix[tetIdx * 3 + 1];
    float4 r2 = _InvRestMatrix[tetIdx * 3 + 2];
    return float3x3(
        r0.x, r0.y, r0.z,
        r1.x, r1.y, r1.z,
        r2.x, r2.y, r2.z
    );
}

// ═══════════════════════════════════════════════════════
// Kernel 0: PreSolve（积分）
// vel += dt*gravity; prevPos = pos; pos += dt*vel
// ═══════════════════════════════════════════════════════
[numthreads(64,1,1)]
void CSIntegrate(uint3 id : SV_DispatchThreadID)
{
    uint i = id.x;
    if (i >= _NumParticles) return;
    if (_InvMasses[i] == 0.0f) return;

    float3 grav = float3(_GravityX, _GravityY, _GravityZ);
    float3 pos  = _Positions[i].xyz;

    // NaN 恢复: 如果上一步产生了 NaN，恢复到 prevPos
    if (isnan(pos.x) || isnan(pos.y) || isnan(pos.z))
    {
        pos = _PrevPositions[i].xyz;
        _Velocities[i] = float4(0, 0, 0, 0);
        _Positions[i] = float4(pos, 0);
        return;
    }

    float3 vel  = _Velocities[i].xyz + _Dt * grav;
    _PrevPositions[i] = float4(pos, 0);
    _Positions[i]     = float4(pos + _Dt * vel, 0);
    _Velocities[i]    = float4(vel, 0);
}

// ═══════════════════════════════════════════════════════
// Kernel 1: SolveEdges（Graph Coloring GS）
// 保留边约束用于额外 damping/stability
// ═══════════════════════════════════════════════════════
[numthreads(64,1,1)]
void CSSolveEdges(uint3 id : SV_DispatchThreadID)
{
    uint li = id.x;
    if (li >= _GroupCount) return;

    uint e = (uint)_EdgeColorGroupFlat[_GroupOffset + li];
    if (e >= _NumEdges) return;
    if (_EdgeActive[e] == 0) return;

    uint2 eids = _EdgeIds[e];
    float w0 = _InvMasses[eids.x];
    float w1 = _InvMasses[eids.y];
    float wTot = w0 + w1;
    if (wTot == 0.0f) return;

    float3 p0 = _Positions[eids.x].xyz;
    float3 p1 = _Positions[eids.y].xyz;
    float3 diff = p0 - p1;
    float l = length(diff);
    if (l == 0.0f) return;

    float3 gradC = diff / l;
    float C = l - _RestLengths[e];
    float lambda = -C / (wTot + _EdgeAlpha) * _Omega;

    _Positions[eids.x] = float4(p0 + lambda * w0 * gradC, 0);
    _Positions[eids.y] = float4(p1 - lambda * w1 * gradC, 0);
}

// ═══════════════════════════════════════════════════════
// Kernel 2: NeoHookean Deviatoric Constraint
// C_dev = tr(F^T · F) - 3
// 参考: FantasyVR/neohookean_XPBD line 96-124
// ═══════════════════════════════════════════════════════
[numthreads(64,1,1)]
void CSSolveNeoHookeanDev(uint3 id : SV_DispatchThreadID)
{
    uint li = id.x;
    if (li >= _GroupCount) return;

    uint t = (uint)_ColorGroupFlat[_GroupOffset + li];
    if (t >= _NumTets) return;
    if (_TetActive[t] == 0) return;

    uint4 ids = _TetIds[t];
    float3 p0 = _Positions[ids.x].xyz;
    float3 p1 = _Positions[ids.y].xyz;
    float3 p2 = _Positions[ids.z].xyz;
    float3 p3 = _Positions[ids.w].xyz;

    // D_s = [p1-p0, p2-p0, p3-p0] (列主序)
    float3 e1 = p1 - p0;
    float3 e2 = p2 - p0;
    float3 e3 = p3 - p0;

    // B = D_m^{-1} (from rest pose)
    float3x3 B = LoadInvRestMatrix(t);

    // F = D_s @ B (变形梯度)
    // F[i,j] = sum_k D_s[i,k] * B[k,j]
    // D_s 列主序: D_s[:,0]=e1, D_s[:,1]=e2, D_s[:,2]=e3
    // → D_s[i,0]=e1[i], D_s[i,1]=e2[i], D_s[i,2]=e3[i]
    float3x3 Ds = float3x3(
        e1.x, e2.x, e3.x,
        e1.y, e2.y, e3.y,
        e1.z, e2.z, e3.z
    );
    float3x3 F = mul(Ds, B);

    // C = tr(F^T · F) - 3
    float rs = dot(F[0], F[0]) + dot(F[1], F[1]) + dot(F[2], F[2]); // = tr(F^T F)
    float constraint = rs - 3.0;

    // G = 2 * F @ B^T (梯度矩阵, 对 p1,p2,p3)
    float3x3 BT = transpose(B);
    float3x3 G = mul(F, BT) * 2.0;

    // g1 = G 的第一列, g2 = 第二列, g3 = 第三列
    float3 g1 = float3(G[0][0], G[1][0], G[2][0]);
    float3 g2 = float3(G[0][1], G[1][1], G[2][1]);
    float3 g3 = float3(G[0][2], G[1][2], G[2][2]);
    float3 g0 = -(g1 + g2 + g3);

    float w0 = _InvMasses[ids.x];
    float w1 = _InvMasses[ids.y];
    float w2 = _InvMasses[ids.z];
    float w3 = _InvMasses[ids.w];

    float sumW = w0 * dot(g0, g0) + w1 * dot(g1, g1) +
                 w2 * dot(g2, g2) + w3 * dot(g3, g3);

    float alpha = _AlphaDeviatoric[t];  // 已在 Init 中烘入 1/(h²*μ*V)
    float denom = sumW + alpha;
    if (denom < 1e-10) return;

    float dlambda = -constraint / denom * _Omega;
    if (isnan(dlambda) || isinf(dlambda)) return;

    _Positions[ids.x] = float4(p0 + w0 * dlambda * g0, 0);
    _Positions[ids.y] = float4(p1 + w1 * dlambda * g1, 0);
    _Positions[ids.z] = float4(p2 + w2 * dlambda * g2, 0);
    _Positions[ids.w] = float4(p3 + w3 * dlambda * g3, 0);
}

// ═══════════════════════════════════════════════════════
// Kernel 3: NeoHookean Hydrostatic Constraint
// C_hyd = det(F) - 1
// 参考: FantasyVR/neohookean_XPBD line 126-156
// ═══════════════════════════════════════════════════════
[numthreads(64,1,1)]
void CSSolveNeoHookeanHyd(uint3 id : SV_DispatchThreadID)
{
    uint li = id.x;
    if (li >= _GroupCount) return;

    uint t = (uint)_ColorGroupFlat[_GroupOffset + li];
    if (t >= _NumTets) return;
    if (_TetActive[t] == 0) return;

    uint4 ids = _TetIds[t];
    // 重新读取位置（deviatoric 已经修改了位置）
    float3 p0 = _Positions[ids.x].xyz;
    float3 p1 = _Positions[ids.y].xyz;
    float3 p2 = _Positions[ids.z].xyz;
    float3 p3 = _Positions[ids.w].xyz;

    float3 e1 = p1 - p0;
    float3 e2 = p2 - p0;
    float3 e3 = p3 - p0;

    float3x3 B = LoadInvRestMatrix(t);
    float3x3 Ds = float3x3(
        e1.x, e2.x, e3.x,
        e1.y, e2.y, e3.y,
        e1.z, e2.z, e3.z
    );
    float3x3 F = mul(Ds, B);

    // F 的列向量
    float3 f1 = float3(F[0][0], F[1][0], F[2][0]); // F 第一列
    float3 f2 = float3(F[0][1], F[1][1], F[2][1]); // F 第二列
    float3 f3 = float3(F[0][2], F[1][2], F[2][2]); // F 第三列

    // Cofactor 矩阵（用于 det(F) 的梯度）
    float3 df0 = cross(f2, f3);
    float3 df1 = cross(f3, f1);
    float3 df2 = cross(f1, f2);

    // G = [df0, df1, df2] @ B^T (cofactor 矩阵 × B 转置)
    float3x3 cofM = float3x3(
        df0.x, df1.x, df2.x,
        df0.y, df1.y, df2.y,
        df0.z, df1.z, df2.z
    );
    float3x3 BT = transpose(B);
    float3x3 G = mul(cofM, BT);

    float3 g1 = float3(G[0][0], G[1][0], G[2][0]);
    float3 g2 = float3(G[0][1], G[1][1], G[2][1]);
    float3 g3 = float3(G[0][2], G[1][2], G[2][2]);
    float3 g0 = -(g1 + g2 + g3);

    // C = det(F) - 1 (手动计算，避免 HLSL determinant 兼容问题)
    float constraint = det3x3(F) - 1.0;

    float w0 = _InvMasses[ids.x];
    float w1 = _InvMasses[ids.y];
    float w2 = _InvMasses[ids.z];
    float w3 = _InvMasses[ids.w];

    float sumW = w0 * dot(g0, g0) + w1 * dot(g1, g1) +
                 w2 * dot(g2, g2) + w3 * dot(g3, g3);

    float alpha = _AlphaHydrostatic[t];  // 已在 Init 中烘入 1/(h²*λ*V)
    float denom = sumW + alpha;
    if (denom < 1e-10) return;

    float dlambda = -constraint / denom * _Omega;
    if (isnan(dlambda) || isinf(dlambda)) return;

    _Positions[ids.x] = float4(p0 + w0 * dlambda * g0, 0);
    _Positions[ids.y] = float4(p1 + w1 * dlambda * g1, 0);
    _Positions[ids.z] = float4(p2 + w2 * dlambda * g2, 0);
    _Positions[ids.w] = float4(p3 + w3 * dlambda * g3, 0);
}

// ═══════════════════════════════════════════════════════
// Kernel 4: PostSolve（速度更新 + 阻尼）
// ═══════════════════════════════════════════════════════
// Fused NeoHookean support: same per-tet dev -> hyd sequence, fewer dispatches.
void SolveNeoHookeanDevTet(uint t)
{
    if (t >= _NumTets) return;
    if (_TetActive[t] == 0) return;

    uint4 ids = _TetIds[t];
    float3 p0 = _Positions[ids.x].xyz;
    float3 p1 = _Positions[ids.y].xyz;
    float3 p2 = _Positions[ids.z].xyz;
    float3 p3 = _Positions[ids.w].xyz;

    float3 e1 = p1 - p0;
    float3 e2 = p2 - p0;
    float3 e3 = p3 - p0;

    float3x3 B = LoadInvRestMatrix(t);
    float3x3 Ds = float3x3(
        e1.x, e2.x, e3.x,
        e1.y, e2.y, e3.y,
        e1.z, e2.z, e3.z
    );
    float3x3 F = mul(Ds, B);

    float rs = dot(F[0], F[0]) + dot(F[1], F[1]) + dot(F[2], F[2]);
    float constraint = rs - 3.0;

    float3x3 BT = transpose(B);
    float3x3 G = mul(F, BT) * 2.0;

    float3 g1 = float3(G[0][0], G[1][0], G[2][0]);
    float3 g2 = float3(G[0][1], G[1][1], G[2][1]);
    float3 g3 = float3(G[0][2], G[1][2], G[2][2]);
    float3 g0 = -(g1 + g2 + g3);

    float w0 = _InvMasses[ids.x];
    float w1 = _InvMasses[ids.y];
    float w2 = _InvMasses[ids.z];
    float w3 = _InvMasses[ids.w];

    float sumW = w0 * dot(g0, g0) + w1 * dot(g1, g1) +
                 w2 * dot(g2, g2) + w3 * dot(g3, g3);

    float denom = sumW + _AlphaDeviatoric[t];
    if (denom < 1e-10) return;

    float dlambda = -constraint / denom * _Omega;
    if (isnan(dlambda) || isinf(dlambda)) return;

    _Positions[ids.x] = float4(p0 + w0 * dlambda * g0, 0);
    _Positions[ids.y] = float4(p1 + w1 * dlambda * g1, 0);
    _Positions[ids.z] = float4(p2 + w2 * dlambda * g2, 0);
    _Positions[ids.w] = float4(p3 + w3 * dlambda * g3, 0);
}

void SolveNeoHookeanHydTet(uint t)
{
    if (t >= _NumTets) return;
    if (_TetActive[t] == 0) return;

    uint4 ids = _TetIds[t];
    float3 p0 = _Positions[ids.x].xyz;
    float3 p1 = _Positions[ids.y].xyz;
    float3 p2 = _Positions[ids.z].xyz;
    float3 p3 = _Positions[ids.w].xyz;

    float3 e1 = p1 - p0;
    float3 e2 = p2 - p0;
    float3 e3 = p3 - p0;

    float3x3 B = LoadInvRestMatrix(t);
    float3x3 Ds = float3x3(
        e1.x, e2.x, e3.x,
        e1.y, e2.y, e3.y,
        e1.z, e2.z, e3.z
    );
    float3x3 F = mul(Ds, B);

    float3 f1 = float3(F[0][0], F[1][0], F[2][0]);
    float3 f2 = float3(F[0][1], F[1][1], F[2][1]);
    float3 f3 = float3(F[0][2], F[1][2], F[2][2]);

    float3 df0 = cross(f2, f3);
    float3 df1 = cross(f3, f1);
    float3 df2 = cross(f1, f2);

    float3x3 cofM = float3x3(
        df0.x, df1.x, df2.x,
        df0.y, df1.y, df2.y,
        df0.z, df1.z, df2.z
    );
    float3x3 BT = transpose(B);
    float3x3 G = mul(cofM, BT);

    float3 g1 = float3(G[0][0], G[1][0], G[2][0]);
    float3 g2 = float3(G[0][1], G[1][1], G[2][1]);
    float3 g3 = float3(G[0][2], G[1][2], G[2][2]);
    float3 g0 = -(g1 + g2 + g3);

    float constraint = det3x3(F) - 1.0;

    float w0 = _InvMasses[ids.x];
    float w1 = _InvMasses[ids.y];
    float w2 = _InvMasses[ids.z];
    float w3 = _InvMasses[ids.w];

    float sumW = w0 * dot(g0, g0) + w1 * dot(g1, g1) +
                 w2 * dot(g2, g2) + w3 * dot(g3, g3);

    float denom = sumW + _AlphaHydrostatic[t];
    if (denom < 1e-10) return;

    float dlambda = -constraint / denom * _Omega;
    if (isnan(dlambda) || isinf(dlambda)) return;

    _Positions[ids.x] = float4(p0 + w0 * dlambda * g0, 0);
    _Positions[ids.y] = float4(p1 + w1 * dlambda * g1, 0);
    _Positions[ids.z] = float4(p2 + w2 * dlambda * g2, 0);
    _Positions[ids.w] = float4(p3 + w3 * dlambda * g3, 0);
}

[numthreads(64,1,1)]
void CSSolveNeoHookeanDevHyd(uint3 id : SV_DispatchThreadID)
{
    uint li = id.x;
    if (li >= _GroupCount) return;

    uint t = (uint)_ColorGroupFlat[_GroupOffset + li];
    if (t >= _NumTets) return;
    if (_TetActive[t] == 0) return;

    uint4 ids = _TetIds[t];
    float3 p0 = _Positions[ids.x].xyz;
    float3 p1 = _Positions[ids.y].xyz;
    float3 p2 = _Positions[ids.z].xyz;
    float3 p3 = _Positions[ids.w].xyz;

    float w0 = _InvMasses[ids.x];
    float w1 = _InvMasses[ids.y];
    float w2 = _InvMasses[ids.z];
    float w3 = _InvMasses[ids.w];

    float3x3 B = LoadInvRestMatrix(t);
    float3x3 BT = transpose(B);

    // Deviatoric solve first, matching SolveNeoHookeanDevTet.
    float3 e1 = p1 - p0;
    float3 e2 = p2 - p0;
    float3 e3 = p3 - p0;
    float3x3 Ds = float3x3(
        e1.x, e2.x, e3.x,
        e1.y, e2.y, e3.y,
        e1.z, e2.z, e3.z
    );
    float3x3 F = mul(Ds, B);
    float rs = dot(F[0], F[0]) + dot(F[1], F[1]) + dot(F[2], F[2]);
    float constraint = rs - 3.0;

    float3x3 G = mul(F, BT) * 2.0;
    float3 g1 = float3(G[0][0], G[1][0], G[2][0]);
    float3 g2 = float3(G[0][1], G[1][1], G[2][1]);
    float3 g3 = float3(G[0][2], G[1][2], G[2][2]);
    float3 g0 = -(g1 + g2 + g3);

    float sumW = w0 * dot(g0, g0) + w1 * dot(g1, g1) +
                 w2 * dot(g2, g2) + w3 * dot(g3, g3);
    float denom = sumW + _AlphaDeviatoric[t];
    if (denom >= 1e-10)
    {
        float dlambda = -constraint / denom * _Omega;
        if (!isnan(dlambda) && !isinf(dlambda))
        {
            p0 += w0 * dlambda * g0;
            p1 += w1 * dlambda * g1;
            p2 += w2 * dlambda * g2;
            p3 += w3 * dlambda * g3;
        }
    }

    // Hydrostatic solve second, using the local dev-updated positions.
    e1 = p1 - p0;
    e2 = p2 - p0;
    e3 = p3 - p0;
    Ds = float3x3(
        e1.x, e2.x, e3.x,
        e1.y, e2.y, e3.y,
        e1.z, e2.z, e3.z
    );
    F = mul(Ds, B);

    float3 f1 = float3(F[0][0], F[1][0], F[2][0]);
    float3 f2 = float3(F[0][1], F[1][1], F[2][1]);
    float3 f3 = float3(F[0][2], F[1][2], F[2][2]);

    float3 df0 = cross(f2, f3);
    float3 df1 = cross(f3, f1);
    float3 df2 = cross(f1, f2);

    float3x3 cofM = float3x3(
        df0.x, df1.x, df2.x,
        df0.y, df1.y, df2.y,
        df0.z, df1.z, df2.z
    );
    G = mul(cofM, BT);

    g1 = float3(G[0][0], G[1][0], G[2][0]);
    g2 = float3(G[0][1], G[1][1], G[2][1]);
    g3 = float3(G[0][2], G[1][2], G[2][2]);
    g0 = -(g1 + g2 + g3);

    constraint = det3x3(F) - 1.0;
    sumW = w0 * dot(g0, g0) + w1 * dot(g1, g1) +
           w2 * dot(g2, g2) + w3 * dot(g3, g3);
    denom = sumW + _AlphaHydrostatic[t];
    if (denom >= 1e-10)
    {
        float dlambda = -constraint / denom * _Omega;
        if (!isnan(dlambda) && !isinf(dlambda))
        {
            p0 += w0 * dlambda * g0;
            p1 += w1 * dlambda * g1;
            p2 += w2 * dlambda * g2;
            p3 += w3 * dlambda * g3;
        }
    }

    _Positions[ids.x] = float4(p0, 0);
    _Positions[ids.y] = float4(p1, 0);
    _Positions[ids.z] = float4(p2, 0);
    _Positions[ids.w] = float4(p3, 0);
}

[numthreads(64,1,1)]
void CSPostSolve(uint3 id : SV_DispatchThreadID)
{
    uint i = id.x;
    if (i >= _NumParticles) return;
    if (_InvMasses[i] == 0.0f) return;

    float3 v = (_Positions[i].xyz - _PrevPositions[i].xyz) / _Dt;
    v *= (1.0 - _Damping);  // 阻尼
    _Velocities[i] = float4(v, 0);
}

// ═══════════════════════════════════════════════════════
// Kernel 5: 地面碰撞
// ═══════════════════════════════════════════════════════
[numthreads(64,1,1)]
void CSGroundCollision(uint3 id : SV_DispatchThreadID)
{
    uint i = id.x;
    if (i >= _NumParticles) return;

    float3 pos = _Positions[i].xyz;
    if (pos.y < _GroundY)
    {
        float3 prev = _PrevPositions[i].xyz;
        prev.y = _GroundY;
        _Positions[i] = float4(prev, 0);
    }
}

// ═══════════════════════════════════════════════════════
// Helper: Point-to-Capsule Signed Distance Field
// ═══════════════════════════════════════════════════════
float4 CapsuleSDF(float3 pos, float3 capA, float3 capB, float capR)
{
    float3 ab = capB - capA;
    float ab2 = dot(ab, ab);
    float t = (ab2 < 1e-10) ? 0.0 : saturate(dot(pos - capA, ab) / ab2);
    float3 closest = capA + t * ab;
    float3 diff = pos - closest;
    float dist = length(diff);
    float sdf = dist - capR;
    float3 normal;
    if (dist < 1e-8)
    {
        float3 abN = (ab2 < 1e-10) ? float3(0, 1, 0) : normalize(ab);
        float3 perp = (abs(abN.x) < 0.9) ? float3(1, 0, 0) : float3(0, 1, 0);
        normal = normalize(cross(abN, perp));
    }
    else
    {
        normal = diff / dist;
    }
    return float4(sdf, normal);
}

float3 ClosestPointOnSegment(float3 p, float3 a, float3 b, out float t)
{
    float3 ab = b - a;
    float ab2 = dot(ab, ab);
    t = (ab2 < 1e-10) ? 0.0 : saturate(dot(p - a, ab) / ab2);
    return a + t * ab;
}

float3 ClosestPointOnTriangle(float3 p, float3 a, float3 b, float3 c, out float3 bary)
{
    float3 ab = b - a;
    float3 ac = c - a;
    float3 ap = p - a;
    float d1 = dot(ab, ap);
    float d2 = dot(ac, ap);
    if (d1 <= 0.0 && d2 <= 0.0)
    {
        bary = float3(1.0, 0.0, 0.0);
        return a;
    }

    float3 bp = p - b;
    float d3 = dot(ab, bp);
    float d4 = dot(ac, bp);
    if (d3 >= 0.0 && d4 <= d3)
    {
        bary = float3(0.0, 1.0, 0.0);
        return b;
    }

    float vc = d1 * d4 - d3 * d2;
    if (vc <= 0.0 && d1 >= 0.0 && d3 <= 0.0)
    {
        float v = d1 / (d1 - d3);
        bary = float3(1.0 - v, v, 0.0);
        return a + v * ab;
    }

    float3 cp = p - c;
    float d5 = dot(ab, cp);
    float d6 = dot(ac, cp);
    if (d6 >= 0.0 && d5 <= d6)
    {
        bary = float3(0.0, 0.0, 1.0);
        return c;
    }

    float vb = d5 * d2 - d1 * d6;
    if (vb <= 0.0 && d2 >= 0.0 && d6 <= 0.0)
    {
        float w = d2 / (d2 - d6);
        bary = float3(1.0 - w, 0.0, w);
        return a + w * ac;
    }

    float va = d3 * d6 - d5 * d4;
    if (va <= 0.0 && (d4 - d3) >= 0.0 && (d5 - d6) >= 0.0)
    {
        float w = (d4 - d3) / ((d4 - d3) + (d5 - d6));
        bary = float3(0.0, 1.0 - w, w);
        return b + w * (c - b);
    }

    float denom = 1.0 / (va + vb + vc);
    float v2 = vb * denom;
    float w2 = vc * denom;
    bary = float3(1.0 - v2 - w2, v2, w2);
    return bary.x * a + bary.y * b + bary.z * c;
}

void ClosestPtSegmentSegment(
    float3 p1, float3 q1, float3 p2, float3 q2,
    out float s, out float t, out float3 c1, out float3 c2)
{
    float3 d1 = q1 - p1;
    float3 d2 = q2 - p2;
    float3 r = p1 - p2;
    float a = dot(d1, d1);
    float e = dot(d2, d2);
    float f = dot(d2, r);

    if (a <= 1e-10 && e <= 1e-10)
    {
        s = 0.0;
        t = 0.0;
        c1 = p1;
        c2 = p2;
        return;
    }

    if (a <= 1e-10)
    {
        s = 0.0;
        t = (e <= 1e-10) ? 0.0 : saturate(f / e);
    }
    else
    {
        float c = dot(d1, r);
        if (e <= 1e-10)
        {
            t = 0.0;
            s = saturate(-c / a);
        }
        else
        {
            float b = dot(d1, d2);
            float denom = a * e - b * b;
            s = (abs(denom) > 1e-10) ? saturate((b * f - c * e) / denom) : 0.0;

            float tNom = b * s + f;
            if (tNom < 0.0)
            {
                t = 0.0;
                s = saturate(-c / a);
            }
            else if (tNom > e)
            {
                t = 1.0;
                s = saturate((b - c) / a);
            }
            else
            {
                t = tNom / e;
            }
        }
    }

    c1 = p1 + d1 * s;
    c2 = p2 + d2 * t;
}

bool SegmentTriangleIntersection(float3 p0, float3 p1, float3 a, float3 b, float3 c, out float3 bary)
{
    float3 d = p1 - p0;
    float3 e1 = b - a;
    float3 e2 = c - a;
    float3 h = cross(d, e2);
    float det = dot(e1, h);
    if (abs(det) < 1e-8)
    {
        bary = float3(0.0, 0.0, 0.0);
        return false;
    }

    float invDet = 1.0 / det;
    float3 s = p0 - a;
    float u = invDet * dot(s, h);
    if (u < 0.0 || u > 1.0)
    {
        bary = float3(0.0, 0.0, 0.0);
        return false;
    }

    float3 q = cross(s, e1);
    float v = invDet * dot(d, q);
    if (v < 0.0 || u + v > 1.0)
    {
        bary = float3(0.0, 0.0, 0.0);
        return false;
    }

    float segT = invDet * dot(e2, q);
    if (segT < 0.0 || segT > 1.0)
    {
        bary = float3(0.0, 0.0, 0.0);
        return false;
    }

    bary = float3(1.0 - u - v, u, v);
    return true;
}

void ConsiderTriCapsuleCandidate(
    float3 triPoint, float3 capPoint, float3 bary, float capR, float3 fallbackNormal,
    inout float bestC, inout float3 bestNormal, inout float3 bestBary)
{
    float3 delta = triPoint - capPoint;
    float dist = length(delta);
    float3 n = delta / max(dist, 1e-8);
    if (dist <= 1e-8)
        n = fallbackNormal;
    float c = dist - capR - _ToolContactDistance;
    if (c < bestC)
    {
        bestC = c;
        bestNormal = n;
        bestBary = bary;
    }
}

void EvaluateTriCapsuleContact(
    float3 a, float3 b, float3 c, float3 capA, float3 capB, float capR,
    inout float bestC, inout float3 bestNormal, inout float3 bestBary)
{
    float shell = capR + _ToolContactDistance;
    float3 triMin = min(a, min(b, c));
    float3 triMax = max(a, max(b, c));
    float3 capMin = min(capA, capB) - shell;
    float3 capMax = max(capA, capB) + shell;
    if (any(triMax < capMin) || any(triMin > capMax))
        return;

    float3 triN = cross(b - a, c - a);
    float nLen = length(triN);
    if (nLen < 1e-10)
        return;

    triN /= nLen;
    float3 triCenter = (a + b + c) * (1.0 / 3.0);
    float3 capMid = (capA + capB) * 0.5;
    if (dot(triN, triCenter - capMid) < 0.0)
        triN = -triN;

    float3 bary;
    if (SegmentTriangleIntersection(capA, capB, a, b, c, bary))
    {
        float3 p = bary.x * a + bary.y * b + bary.z * c;
        ConsiderTriCapsuleCandidate(p, p, bary, capR, triN, bestC, bestNormal, bestBary);
    }

    float3 pt = ClosestPointOnTriangle(capA, a, b, c, bary);
    ConsiderTriCapsuleCandidate(pt, capA, bary, capR, triN, bestC, bestNormal, bestBary);

    pt = ClosestPointOnTriangle(capB, a, b, c, bary);
    ConsiderTriCapsuleCandidate(pt, capB, bary, capR, triN, bestC, bestNormal, bestBary);

    float segT;
    float3 cp = ClosestPointOnSegment(a, capA, capB, segT);
    ConsiderTriCapsuleCandidate(a, cp, float3(1.0, 0.0, 0.0), capR, triN, bestC, bestNormal, bestBary);

    cp = ClosestPointOnSegment(b, capA, capB, segT);
    ConsiderTriCapsuleCandidate(b, cp, float3(0.0, 1.0, 0.0), capR, triN, bestC, bestNormal, bestBary);

    cp = ClosestPointOnSegment(c, capA, capB, segT);
    ConsiderTriCapsuleCandidate(c, cp, float3(0.0, 0.0, 1.0), capR, triN, bestC, bestNormal, bestBary);

    float sCap, sEdge;
    float3 capPt, edgePt;
    ClosestPtSegmentSegment(capA, capB, a, b, sCap, sEdge, capPt, edgePt);
    ConsiderTriCapsuleCandidate(edgePt, capPt, float3(1.0 - sEdge, sEdge, 0.0), capR, triN, bestC, bestNormal, bestBary);

    ClosestPtSegmentSegment(capA, capB, b, c, sCap, sEdge, capPt, edgePt);
    ConsiderTriCapsuleCandidate(edgePt, capPt, float3(0.0, 1.0 - sEdge, sEdge), capR, triN, bestC, bestNormal, bestBary);

    ClosestPtSegmentSegment(capA, capB, c, a, sCap, sEdge, capPt, edgePt);
    ConsiderTriCapsuleCandidate(edgePt, capPt, float3(sEdge, 0.0, 1.0 - sEdge), capR, triN, bestC, bestNormal, bestBary);
}

void EvaluateSweptTriCapsuleContact(
    float3 a, float3 b, float3 c,
    float3 capA, float3 capB, float3 prevA, float3 prevB, float capR,
    inout float bestC, inout float3 bestNormal, inout float3 bestBary)
{
    EvaluateTriCapsuleContact(a, b, c, capA, capB, capR, bestC, bestNormal, bestBary);
    EvaluateTriCapsuleContact(a, b, c, prevA, prevB, capR, bestC, bestNormal, bestBary);
    EvaluateTriCapsuleContact(a, b, c, (capA + prevA) * 0.5, (capB + prevB) * 0.5, capR, bestC, bestNormal, bestBary);

    EvaluateTriCapsuleContact(a, b, c, prevA, capA, capR, bestC, bestNormal, bestBary);
    EvaluateTriCapsuleContact(a, b, c, prevB, capB, capR, bestC, bestNormal, bestBary);
}

bool TriAabbOverlapsCapsuleSweep(
    float3 triMin, float3 triMax,
    float3 capA, float3 capB, float3 prevA, float3 prevB, float capR)
{
    float shell = capR + _ToolContactDistance;
    float3 capMin = min(min(capA, capB), min(prevA, prevB)) - shell;
    float3 capMax = max(max(capA, capB), max(prevA, prevB)) + shell;
    return !(any(triMax < capMin) || any(triMin > capMax));
}

void EvaluateSweptTriCapsuleContactFiltered(
    float3 a, float3 b, float3 c, float3 triMin, float3 triMax,
    float3 capA, float3 capB, float3 prevA, float3 prevB, float capR,
    inout float bestC, inout float3 bestNormal, inout float3 bestBary)
{
    if (!TriAabbOverlapsCapsuleSweep(triMin, triMax, capA, capB, prevA, prevB, capR))
        return;

    EvaluateSweptTriCapsuleContact(
        a, b, c, capA, capB, prevA, prevB, capR,
        bestC, bestNormal, bestBary);
}

[numthreads(64,1,1)]
void CSSolveSurfaceToolContacts(uint3 id : SV_DispatchThreadID)
{
    uint li = id.x;
    if (li >= _SurfaceGroupCount) return;

    int numCapsules = (int)_ToolBBoxMax.w;
    if (numCapsules <= 0) return;

    uint triIdx = (uint)_SurfaceTriColorGroupFlat[_SurfaceGroupOffset + li];
    if (triIdx >= _NumSurfaceTris) return;

    uint3 ids = _SurfaceTriIds[triIdx];
    float w0 = _InvMasses[ids.x];
    float w1 = _InvMasses[ids.y];
    float w2 = _InvMasses[ids.z];
    if (w0 + w1 + w2 <= 0.0) return;

    float3 p0 = _Positions[ids.x].xyz;
    float3 p1 = _Positions[ids.y].xyz;
    float3 p2 = _Positions[ids.z].xyz;
    float3 triMin = min(p0, min(p1, p2));
    float3 triMax = max(p0, max(p1, p2));
    if (any(triMax < _ToolBBoxMin.xyz) || any(triMin > _ToolBBoxMax.xyz))
        return;

    float3 prev0 = _PrevPositions[ids.x].xyz;
    float3 prev1 = _PrevPositions[ids.y].xyz;
    float3 prev2 = _PrevPositions[ids.z].xyz;

    for (int contactPass = 0; contactPass < 2; contactPass++)
    {
        float bestC = 1e20;
        float3 bestNormal = float3(0.0, 1.0, 0.0);
        float3 bestBary = float3(0.0, 0.0, 0.0);

        if (numCapsules >= 1)
            EvaluateSweptTriCapsuleContactFiltered(p0, p1, p2, triMin, triMax, _Capsule0A.xyz, _Capsule0B.xyz, _PrevCapsule0A.xyz, _PrevCapsule0B.xyz, _Capsule0A.w, bestC, bestNormal, bestBary);
        if (numCapsules >= 2)
            EvaluateSweptTriCapsuleContactFiltered(p0, p1, p2, triMin, triMax, _Capsule1A.xyz, _Capsule1B.xyz, _PrevCapsule1A.xyz, _PrevCapsule1B.xyz, _Capsule1A.w, bestC, bestNormal, bestBary);
        if (numCapsules >= 3)
            EvaluateSweptTriCapsuleContactFiltered(p0, p1, p2, triMin, triMax, _Capsule2A.xyz, _Capsule2B.xyz, _PrevCapsule2A.xyz, _PrevCapsule2B.xyz, _Capsule2A.w, bestC, bestNormal, bestBary);

        if (bestC >= 0.0)
            break;

        float b0 = bestBary.x;
        float b1 = bestBary.y;
        float b2 = bestBary.z;
        float denom = w0 * b0 * b0 + w1 * b1 * b1 + w2 * b2 * b2;
        if (denom <= 1e-12)
            break;

        float dlambda = (-bestC) / (denom + max(_ToolContactAlpha, 0.0));
        float3 dx = dlambda * bestNormal;

        p0 += w0 * b0 * dx;
        p1 += w1 * b1 * dx;
        p2 += w2 * b2 * dx;

        float3 contactNow = b0 * p0 + b1 * p1 + b2 * p2;
        float3 contactPrev = b0 * prev0 + b1 * prev1 + b2 * prev2;
        float vn = dot(contactNow - contactPrev, bestNormal);

        if (vn < 0.0)
        {
            float3 prevDx = vn * bestNormal;
            prev0 += (w0 * b0 / denom) * prevDx;
            prev1 += (w1 * b1 / denom) * prevDx;
            prev2 += (w2 * b2 / denom) * prevDx;
        }
    }

    _Positions[ids.x] = float4(p0, 0.0);
    _Positions[ids.y] = float4(p1, 0.0);
    _Positions[ids.z] = float4(p2, 0.0);
    _PrevPositions[ids.x] = float4(prev0, 0.0);
    _PrevPositions[ids.y] = float4(prev1, 0.0);
    _PrevPositions[ids.z] = float4(prev2, 0.0);
}

// ═══════════════════════════════════════════════════════
// Kernel 6: 夹爪碰撞 — Multi-Capsule SDF 位置投影
// 3个胶囊体: 0=上颚, 1=下颚, 2=杆身(shaft)
// ★ 关键: 碰撞时同时修正 prevPos，消除向工具方向的速度
//   否则下一子步粒子又冲回去 (SOFA contact velocity correction)
// ═══════════════════════════════════════════════════════
[numthreads(64,1,1)]
void CSToolCollision(uint3 id : SV_DispatchThreadID)
{
    uint i = id.x;
    if (i >= _NumParticles) return;
    if (_InvMasses[i] == 0.0) return;

    int numCapsules = (int)_ToolBBoxMax.w;
    if (numCapsules <= 0) return;

    float3 pos = _Positions[i].xyz;
    float3 prevPos = _PrevPositions[i].xyz;
    bool collided = false;
    float3 lastNormal = float3(0, 1, 0);

    // Capsule 0 (上颚)
    if (numCapsules >= 1)
    {
        float4 res = CapsuleSDF(pos, _Capsule0A.xyz, _Capsule0B.xyz, _Capsule0A.w);
        if (res.x < 0.0)
        {
            pos -= res.x * res.yzw;
            collided = true;
            lastNormal = res.yzw;
        }
    }

    // Capsule 1 (下颚)
    if (numCapsules >= 2)
    {
        float4 res = CapsuleSDF(pos, _Capsule1A.xyz, _Capsule1B.xyz, _Capsule1A.w);
        if (res.x < 0.0)
        {
            pos -= res.x * res.yzw;
            collided = true;
            lastNormal = res.yzw;
        }
    }

    // Capsule 2 (杆身/shaft)
    if (numCapsules >= 3)
    {
        float4 res = CapsuleSDF(pos, _Capsule2A.xyz, _Capsule2B.xyz, _Capsule2A.w);
        if (res.x < 0.0)
        {
            pos -= res.x * res.yzw;
            collided = true;
            lastNormal = res.yzw;
        }
    }

    if (collided)
    {
        // ★ 速度修正: 消除粒子向工具方向的速度分量
        // 没有这一步，粒子会在下一子步又冲回胶囊体内
        float3 vel = pos - prevPos;  // 位移 = 速度 * dt
        float vn = dot(vel, lastNormal);
        if (vn < 0.0)  // 粒子正在向工具移动
        {
            prevPos += vn * lastNormal;  // 取消这个方向的速度
        }
        _PrevPositions[i] = float4(prevPos, 0);
    }

    _Positions[i] = float4(pos, 0);
}
